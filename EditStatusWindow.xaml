<Window x:Class="DEMO1.EditStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение статуса заказа" 
        Height="250" 
        Width="400" 
        WindowStartupLocation="CenterOwner">

    <Grid Background="#F5DEB3" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Изменение статуса заказа" 
                   FontSize="16" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"
                   Grid.Row="0"/>

        <TextBlock Text="Номер заказа:" Grid.Row="1" Margin="0,5"/>
        <TextBlock x:Name="OrderNumberText" 
                   Grid.Row="2" 
                   Margin="0,5" 
                   FontWeight="Bold"
                   FontSize="14"/>

        <TextBlock Text="Новый статус:" Grid.Row="3" Margin="0,15,0,5"/>
        <ComboBox x:Name="StatusComboBox" 
                  Grid.Row="4" 
                  Height="30" 
                  Margin="0,0,0,20">
            <ComboBoxItem Content="Новый"/>
            <ComboBoxItem Content="Завершен"/>
            <ComboBoxItem Content="Отменен"/>
            <ComboBoxItem Content="В обработке"/>
        </ComboBox>

        <StackPanel Orientation="Horizontal" 
                    Grid.Row="5" 
                    HorizontalAlignment="Center" 
                    Margin="0,20">
            <Button Content="Сохранить" 
                    Width="100" 
                    Height="35" 
                    Margin="10" Background="#DEB887"
                    Click="SaveButton_Click"/>
            <Button Content="Отмена" 
                    Width="100" 
                    Height="35" 
                    Margin="10" 
                    Click="CancelButton_Click"
                    Background="#DEB887"/>
        </StackPanel>
    </Grid>
</Window>