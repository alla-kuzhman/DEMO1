<Window x:Class="DEMO1.OrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DEMO1"
        mc:Ignorable="d"
        Title="Управление заказами" Height="500" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Управление заказами" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15" Grid.Row="0"/>
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,10" HorizontalAlignment="Center">
            <Button x:Name="RefreshButton" Content="Обновить" Width="120" Height="35" Margin="5" Click="RefreshButton_Click" Background="LightBlue"/>
            <Button x:Name="EditStatusButton" Content="Изменить статус" Width="150" Height="35" Margin="5" Click="EditStatusButton_Click" Background="LightGreen"/>
            <Button x:Name="AddOrderButton" Content="Добавить заказ" Width="140" Height="35" Margin="5" Click="AddOrderButton_Click" Background="LightYellow"/>
            <Button x:Name="DeleteOrderButton" Content="Удалить заказ" Width="130" Height="35" Margin="5" Click="DeleteOrderButton_Click" Background="LightCoral"/>
        </StackPanel>
        <DataGrid x:Name="OrdersGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single" AlternatingRowBackground="LightGray" FontSize="13">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Номер заказа" Binding="{Binding OrderNumber}" Width="100"/>
                <DataGridTextColumn Header="Дата заказа" Binding="{Binding DeliveryDate, StringFormat='dd.MM.yyyy'}" Width="100"/>
                <DataGridTextColumn Header="Пункт выдачи" Binding="{Binding PickupPoint}" Width="200"/>
                <DataGridTextColumn Header="Кдиент" Binding="{Binding ClientName}" Width="150"/>
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
        <TextBlock x:Name="InfoText" Grid.Row="3" Margin="0,10" HorizontalAlignment="Center" FontStyle="Italic" Foreground="Gray"/>
    </Grid>
</Window>
